{
  "name": "flow-md-enhance",
  "displayName": "FlowMD Enhance",
  "description": "WYSIWYG Markdown Editor with full HTML tag support for VS Code",
  "version": "0.2.1",
  "publisher": "linlucifer",
  "icon": "md_logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/anyueruhui/flow_md_enhance.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:flowMdEnhance.editor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "FlowMD Enhance",
      "properties": {
        "flowMdEnhance.defaultMode": {
          "type": "string",
          "default": "live",
          "enum": [
            "live",
            "viewer",
            "source"
          ],
          "enumDescriptions": [
            "Live Preview — block-level editing",
            "Viewer — read-only rendered preview",
            "Source — raw Markdown editing"
          ],
          "description": "Default editing mode when opening a Markdown file"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "flowMdEnhance.editor",
        "displayName": "FlowMD Enhance",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "flowMdEnhance.open",
        "title": "FlowMD Enhance: Open Markdown"
      }
    ]
  },
  "scripts": {
    "build": "node build.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.21.0",
    "markdown-it": "^14.1.0",
    "markdown-it-task-checkbox": "^1.0.0",
    "dompurify": "^3.0.0",
    "jsdom": "^24.0.0"
  }
}
